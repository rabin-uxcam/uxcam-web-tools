{
  "name": "canvas-to-video",
  "version": "1.0.0",
  "description": "Test tool: loads canvas batch .bin files from MinIO/S3 and converts them to video",
  "type": "module",
  "scripts": {
    "start": "node index.mjs",
    "convert": "node index.mjs",
    "validate": "node validate-sync.mjs",
    "player": "open player.html",
    "serve": "node server.mjs",
    "bench": "node docker-bench.mjs",
    "bench:docker:build": "docker build -f Dockerfile.bench -t bin-bench .",
    "bench:docker": "docker run --rm --cpus=2 --memory=2000m --memory-swap=2000m -v $(pwd)/output:/app/output -e MINIO_ENDPOINT=http://host.docker.internal:9000 bin-bench"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "sharp": "^0.33.0"
  }
}
